# TestRail instance URL — no trailing slash
TESTRAIL_URL=https://yourorg.testrail.io

# TestRail login email
TESTRAIL_EMAIL=your@email.com

# TestRail API key — generate one in My Settings → API Keys in TestRail
TESTRAIL_API_KEY=your_api_key_here

# Transport: "http" for Docker/remote use, "stdio" for local Claude Desktop / Cursor use
TRANSPORT=http

# Port the HTTP server listens on (only used when TRANSPORT=http)
PORT=8000
